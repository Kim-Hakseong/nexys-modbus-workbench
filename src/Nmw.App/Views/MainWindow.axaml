<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Nmw.App.ViewModels"
        x:Class="Nmw.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Title="Modbus Workbench"
        Icon="/Assets/app.ico"
        Width="1280" Height="760"
        MinWidth="980" MinHeight="600">
  <Window.Styles>
    <Style Selector="WrapPanel#ToolbarPanel > :is(Control)">
      <Setter Property="Margin" Value="0,3,6,3" />
    </Style>
  </Window.Styles>
  <DockPanel Margin="16">

    <!-- 상단 바 카드 -->
    <Border DockPanel.Dock="Top" Classes="card" Padding="10,8" Margin="0,0,0,12">
      <DockPanel>
        <Border DockPanel.Dock="Left" Classes="pill" VerticalAlignment="Center" Background="{StaticResource CardBrush}">
          <TextBlock Text="Modbus Workbench" FontWeight="SemiBold" FontSize="14" />
        </Border>
        <TextBlock DockPanel.Dock="Right" Text="{Binding ConnectionStatus}" Classes="muted"
                   VerticalAlignment="Center" Margin="12,0,6,0" />
        <WrapPanel x:Name="ToolbarPanel" Margin="12,0,0,0" VerticalAlignment="Center">
          <Button x:Name="ConnectButton" Click="OnConnectClick" Classes="accent">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconLink}" />
              <TextBlock Text="연결" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Command="{Binding DisconnectCommand}" IsEnabled="{Binding IsConnected}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconLinkOff}" />
              <TextBlock Text="해제" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Click="OnWriteClick" IsEnabled="{Binding IsConnected}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconEdit}" />
              <TextBlock Text="쓰기" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <ToggleButton IsChecked="{Binding OneBasedAddress}" ToolTip.Tip="프로토콜 주소(0-base) ↔ PLC 표기(40001)">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconTag}" />
              <TextBlock Text="PLC 주소" VerticalAlignment="Center" />
            </StackPanel>
          </ToggleButton>
          <Button Command="{Binding AddPollCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconAdd}" />
              <TextBlock Text="폴 추가" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Command="{Binding RemoveSelectedPollCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconRemove}" />
              <TextBlock Text="폴 삭제" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Click="OnOpenWorkspaceClick">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconFolder}" />
              <TextBlock Text="열기" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Click="OnSaveWorkspaceClick">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconSave}" />
              <TextBlock Text="저장" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Click="OnSimulatorClick">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconChip}" />
              <TextBlock Text="시뮬레이터" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Click="OnHelpClick" ToolTip.Tip="간단 사용설명서 (시작 시 자동 표시)">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconHelp}" />
              <TextBlock Text="도움말" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </WrapPanel>
      </DockPanel>
    </Border>

    <!-- 하단 상태 라인 + 로고/저작권 -->
    <Border DockPanel.Dock="Bottom" Padding="12,8,12,2">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="© 2026 NEXYS Co., Ltd. All rights reserved." Classes="muted" FontSize="11"
                     VerticalAlignment="Center" />
          <Image Source="/Assets/nexys-logo.png" Height="14" VerticalAlignment="Center"
                 RenderOptions.BitmapInterpolationMode="HighQuality" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="18">
          <TextBlock Text="{Binding ConnectionStatus}" Classes="muted" />
          <TextBlock Text="{Binding SelectedPoll.StatsText}" Classes="muted" />
          <TextBlock Text="{Binding GlobalMessage}" Classes="error" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 트래픽 로그 카드 (접이식) -->
    <Border DockPanel.Dock="Bottom" Classes="card" Margin="0,12,0,0" Padding="10,6">
      <Expander Header="트래픽 로그" IsExpanded="False">
        <DockPanel Height="200" Margin="0,6,0,0">
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="2,0,2,8">
            <ToggleButton IsChecked="{Binding TrafficLog.ErrorsOnly}" FontSize="12" Padding="12,5">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconWarning}" Width="13" Height="13" />
                <TextBlock Text="에러만" VerticalAlignment="Center" />
              </StackPanel>
            </ToggleButton>
            <Button Command="{Binding TrafficLog.ClearCommand}" FontSize="12" Padding="12,5">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconTrash}" Width="13" Height="13" />
                <TextBlock Text="클리어" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Click="OnSaveLogClick" FontSize="12" Padding="12,5">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconDownload}" Width="13" Height="13" />
                <TextBlock Text="저장" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <TextBlock Text="{Binding TrafficLog.SummaryText}" Classes="muted" VerticalAlignment="Center" Margin="8,0,0,0" />
          </StackPanel>
          <Border Classes="softCard" Padding="8">
            <ListBox ItemsSource="{Binding TrafficLog.VisibleLines}"
                     FontFamily="Menlo,Consolas,monospace" FontSize="12" />
          </Border>
        </DockPanel>
      </Expander>
    </Border>

    <!-- 폴 탭 카드 -->
    <Border Classes="card" Padding="14">
      <TabControl ItemsSource="{Binding Polls}" SelectedItem="{Binding SelectedPoll}">
        <TabControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
          <DataTemplate>
            <DockPanel>

              <!-- 폴 설정 (라벨 위 + 입력 아래) -->
              <Border DockPanel.Dock="Top" Classes="softCard" Padding="12,10" Margin="0,4,0,10">
                <WrapPanel>
                  <StackPanel Margin="0,0,14,6">
                    <TextBlock Classes="fieldLabel" Text="이름" />
                    <TextBox Text="{Binding Name}" Width="120" Watermark="예: 보일러 온도" />
                  </StackPanel>
                  <StackPanel Margin="0,0,14,6">
                    <TextBlock Classes="fieldLabel" Text="Unit ID" />
                    <TextBox Text="{Binding UnitIdText}" Width="60" Watermark="예: 1" />
                  </StackPanel>
                  <StackPanel Margin="0,0,14,6">
                    <TextBlock Classes="fieldLabel" Text="Function" />
                    <ComboBox ItemsSource="{Binding FunctionOptions}" SelectedIndex="{Binding FunctionIndex}" Width="170" />
                  </StackPanel>
                  <StackPanel Margin="0,0,14,6">
                    <TextBlock Classes="fieldLabel" Text="시작 주소" />
                    <TextBox Text="{Binding StartAddressText}" Width="90" Watermark="예: 0 / 40001" />
                  </StackPanel>
                  <StackPanel Margin="0,0,14,6">
                    <TextBlock Classes="fieldLabel" Text="개수" />
                    <TextBox Text="{Binding QuantityText}" Width="60" Watermark="예: 10" />
                  </StackPanel>
                  <StackPanel Margin="0,0,14,6">
                    <TextBlock Classes="fieldLabel" Text="주기(ms)" />
                    <TextBox Text="{Binding ScanRateText}" Width="80" Watermark="예: 500" />
                  </StackPanel>
                  <StackPanel Margin="0,0,14,6">
                    <TextBlock Classes="fieldLabel" Text="포맷" />
                    <ComboBox ItemsSource="{Binding FormatOptions}" SelectedIndex="{Binding FormatIndex}" Width="110" />
                  </StackPanel>
                  <StackPanel Margin="0,0,18,6">
                    <TextBlock Classes="fieldLabel" Text="워드오더" />
                    <ComboBox ItemsSource="{Binding WordOrderOptions}" SelectedIndex="{Binding WordOrderIndex}" Width="170" />
                  </StackPanel>
                  <StackPanel Margin="0,0,12,6" VerticalAlignment="Bottom">
                    <Button Command="{Binding TogglePollCommand}" Classes="accent">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <PathIcon Data="{StaticResource IconPlay}" />
                        <TextBlock Text="폴 시작/정지" VerticalAlignment="Center" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                  <StackPanel Margin="0,0,12,6" VerticalAlignment="Bottom">
                    <Border Classes="inkChip" VerticalAlignment="Center">
                      <TextBlock Text="{Binding StatsText}" Foreground="#FFFFFF" FontSize="12" />
                    </Border>
                  </StackPanel>
                  <StackPanel Margin="0,0,0,6" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding LastError}" Classes="error" VerticalAlignment="Center" Margin="0,0,0,6" />
                  </StackPanel>
                </WrapPanel>
              </Border>

              <!-- 폴 그리드 -->
              <DataGrid ItemsSource="{Binding Rows}"
                        AutoGenerateColumns="False"
                        CanUserReorderColumns="False"
                        DoubleTapped="OnGridDoubleTapped"
                        Margin="4,0,4,4">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="주소" Binding="{Binding Address}" Width="140" IsReadOnly="True" />
                  <DataGridTextColumn Header="별칭" Binding="{Binding Alias}" Width="180" IsReadOnly="False" />
                  <DataGridTextColumn Header="값" Binding="{Binding Value}" Width="*" IsReadOnly="True" />
                </DataGrid.Columns>
              </DataGrid>

            </DockPanel>
          </DataTemplate>
        </TabControl.ContentTemplate>
      </TabControl>
    </Border>

  </DockPanel>
</Window>
